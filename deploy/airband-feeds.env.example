# Secrets for the airband-feeds systemd unit (airband-feeds.service).
#
# These are expanded into feeds.json's ${AIRBAND_*} references at startup, so the
# committed feeds.json never contains a password. Install on the Pi as:
#
#   sudo cp deploy/airband-feeds.env.example /etc/airband-feeds.env
#   sudo $EDITOR /etc/airband-feeds.env        # fill in the real passwords
#   sudo chown root:root /etc/airband-feeds.env
#   sudo chmod 600 /etc/airband-feeds.env
#   sudo systemctl restart airband-feeds
#
# Do NOT commit the filled-in file. *.env is gitignored; this *.example is the
# only env file tracked in the repo.

# Source password for the local Icecast server (icecast.chongflix.tv).
AIRBAND_ICECAST_PASSWORD=changeme

# Source password assigned by LiveATC for audio-in.liveatc.net:8010.
AIRBAND_LIVEATC_PASSWORD=changeme

# --- MQTT -> Home Assistant -----------------------------------------------
# airband-feeds.service passes --mqtt-broker/--mqtt-user/--mqtt-pass = these vars.
# Leave AIRBAND_MQTT_BROKER empty (or unset) to disable MQTT — the reader treats
# an empty broker as "off", so the unit needs no separate MQTT-less variant.
# When set, the reader publishes a retained JSON state topic plus Home Assistant
# MQTT discovery configs (entities auto-appear, no manual YAML), and a Last Will
# flips availability to "offline" the instant the feeder dies.
AIRBAND_MQTT_BROKER=10.0.16.9
AIRBAND_MQTT_USER=plutoplus
AIRBAND_MQTT_PASS=changeme

# --- Optional: failure alerting -------------------------------------------
# Webhook or ntfy topic URL the OnFailure= hook (airband-alert@.service) POSTs to
# when the feeder crashes or its watchdog trips. Unset = log-only.
#AIRBAND_ALERT_URL=https://ntfy.sh/your-secret-topic
