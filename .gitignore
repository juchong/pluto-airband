# Python virtual environment (recreate from requirements-dev.lock.txt)
.venv/

# Upstream dependencies — cloned separately, pinned by SHA in BUILD.md.
# We build *on top of* these and do not track or modify their trees.
maia-sdr/
plutosdr-fw/
libiio/

# Python caches
__pycache__/
*.py[cod]
*.egg-info/

# Simulation / build artifacts
sim_build/
results.xml
dut.v
*.vcd
*.cs16
*.frm
*.dfu
hdl/out/

# OS / editor cruft
.DS_Store

# Local diagnostic captures/analysis (IQ recordings, WAVs, plots, scripts, logs)
.ch9-analysis/

# Built firmware images (large binaries)
firmware/images/
firmware/build/

# Rust build artifacts (host reader)
target/

# Deployment secrets: feeds.json passwords come from an EnvironmentFile that is
# never tracked. The committed deploy/airband-feeds.env.example is the template.
*.env
!*.env.example
